; Stage 2 plugin extraction generator is identical to Stage 1
(subdir stage2-plugins-gen

 (rule
  (target plugins.build.inc)
  (deps)
  (action (with-stdout-to %{target}
    (run %{env:FSTAR2_EXE=fstar.exe}
         --dep dune --output_ext fst.checked.lax --lax
         --no_default_includes
         --include %{workspace_root}/../../../ulib
         --extract ",*"
