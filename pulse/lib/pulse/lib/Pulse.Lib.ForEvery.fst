    forall+ (xy : a & b). f xy._1 xy._2
{
  forevery_intro_false (fun (xy: a & b) -> f xy._1 xy._2);
  forevery_rec (fun x -> forall+ y. f x y)
    (fun pred -> forall+ (xy: a & b { pred (fst xy) }). f xy._1 xy._2)
    fn pred add g {
