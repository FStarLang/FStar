let bij_mirror_n (n:nat) : (fin n =~ fin n) =
  {
    right = (fun (i:fin n) -> n - 1 - i <: fin n);
    left = (fun (i:fin n) -> n - 1 - i <: fin n);
    right_left = easy;
    left_right = easy;
  }


