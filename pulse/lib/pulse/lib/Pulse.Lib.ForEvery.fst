    }
    fn pred xy {
      forevery_singleton_intro' (fun (x: a { x == xy._1 }) -> f x xy._2) xy._1;
      forevery_unrefine_pred (fun x -> f x xy._2) (fun x -> x == xy._1);
      forevery_zip
