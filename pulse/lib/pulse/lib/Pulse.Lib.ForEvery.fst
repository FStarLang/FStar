  forevery_intro_fill (fun (x:a {~(f x)}) -> when_ (f x) (p x))
    fn x { rewrite emp as when_ (f x) (p x) };
  forevery_refine_join (fun x -> when_ (f x) (p x)) f (fun x -> ~(f x));
  forevery_unrefine (fun x -> when_ (f x) (p x));
