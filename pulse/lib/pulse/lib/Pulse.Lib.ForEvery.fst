ghost
fn forevery_rw_size
  (n1 : nat)
  (n2 : nat{n1 == n2})
  (#p : fin n1 -> slprop)
  requires
    forall+ (i : fin n1). p i
  ensures
    forall+ (i : fin n2). p i
{
  rewrite each n1 as n2;
}

