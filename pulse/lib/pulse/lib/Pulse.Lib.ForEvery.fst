module Pulse.Lib.ForEvery

#lang-pulse
open FStar.Fin
open FStar.Bijection
open FStar.Enumerable
open Pulse.Lib.Trade
open FStar.FunctionalExtensionality { (^->) }
module F = FStar.FunctionalExtensionality
open FStar.Tactics.Easy { easy }

let timeless_emp (v:slprop)
: Lemma
  (requires v==emp)
  (ensures timeless v)
  [SMTPat (timeless v)]
= let x = timeless_emp in ()

let forallm_tag #a ([@@@mkey] s: a -> prop) ([@@@mkey] p: a -> slprop)
    (f: (x:a { s x }) -> stt_ghost unit emp_inames emp (fun _ -> p x)) : timeless_slprop =
  emp

// A universal quantifier with no closure resource (i.e., timeless and duplicable)
let forallm #a ([@@@mkey] s: a -> prop) ([@@@mkey] p: a -> slprop) : timeless_slprop =
  exists* f. forallm_tag s p f

ghost
fn forallm_intro u#a
  (#a: Type u#a) (s: a -> prop) (p: a -> slprop)
  (f: (x:a { s x }) -> stt_ghost unit emp_inames emp (fun _ -> p x))
  ensures
    forallm s (fun x -> p x)
{
  fold forallm_tag s (fun x -> p x) f;
  fold forallm s (fun x -> p x);
}

ghost fn forallm_get_elim u#a (#a: Type u#a) (s: a -> prop) (p: a -> slprop)
  requires
    forallm s (fun x -> p x)
  returns
    f: ((x:a { s x }) -> stt_ghost unit emp_inames emp (fun _ -> p x))
{
  unfold forallm s (fun x -> p x);
  with f. assert forallm_tag s (fun x -> p x) f;
  unfold forallm_tag s (fun x -> p x) f;
  reveal f;
}

ghost
fn forallm_dup u#a (#a: Type u#a) (s: a -> prop) (p: a -> slprop) () : duplicable_f (forallm s (fun x -> p x)) = {
  let f = forallm_get_elim s p;
  forallm_intro s p f;
  forallm_intro s p f;
}
instance forallm_duplicable (#a: Type u#a) (s: a -> prop) (p: a -> slprop) : duplicable (forallm s (fun x -> p x)) =
  { dup_f = forallm_dup s p }

(*
We set up `forall+` as an inductively defined slprop generated by the following three constructors:
  | Empty: forall+ (x:a {False}). p x
  | Fill: forall* (pred add: a->prop).
      (forallm add p ** forall+ (x:a {pred x}). p x) @==>
        forall+ (x:a { pred x \/ add x }). p x
  | Insert: forall* (pred: a->prop) (y: a).
      (p y ** forall+ (x:a { pred x }). p x) @==>
        forall+ (x:a { pred x \/ x == y}). p x

Pulse does not have inductively defined predicates (yet?), so we simulate it by
defining an inductive shape type, and then defining the slprop by recursion on
that shape.

Later in the file we'll get the obvious definitions for this type:
  - `forevery_rec`: a recursor
  - `forevery_intro_false`: the constructor for Empty
  - `forevery_fill`: the constructor for Fill
  - `forevery_insert`: the constructor for Insert
*)

noextract noeq type shape =
  | Empty
  | Fill of shape
  | Insert of shape

let rec forevery_aux (#a: Type u#a) (p: a -> slprop) (s: shape) (mask: a -> prop) : slprop =
  match s with
  | Empty -> pure (forall x. ~(mask x))
  | Fill s -> exists* (pred: a -> prop).
    forallm pred (fun x -> p x) ** forevery_aux p s (fun x -> mask x /\ ~(pred x))
  | Insert s -> exists* y. p y ** pure (mask y) ** forevery_aux p s (fun x -> mask x /\ x =!= y)

let timeless_exists' (#a:Type u#a) (p: a -> slprop) (h: (x:a -> squash (timeless (p x)))) :
    squash (timeless (exists* x. p x)) =
  introduce forall x. timeless (p x) with h x;
  timeless_exists p

let rec timeless_forevery_aux (#a: Type u#a) (p: a -> timeless_slprop) (s: shape) (mask: a -> prop) :
    squash (timeless (forevery_aux p s mask)) =
  match s with
  | Empty -> ()
  | Fill s ->
    assert_norm (forevery_aux p (Fill s) mask ==
      exists* (pred: a -> prop).
        forallm pred (fun x -> p x) ** forevery_aux p s (fun x -> mask x /\ ~(pred x)));
    timeless_exists' (fun (pred: a -> prop) ->
        forallm pred (fun x -> p x) ** forevery_aux p s (fun x -> mask x /\ ~(pred x)))
      (fun pred -> timeless_forevery_aux p s (fun x -> mask x /\ ~(pred x)))
  | Insert s ->
    assert_norm (forevery_aux p (Insert s) mask ==
      exists* y. p y ** pure (mask y) ** forevery_aux p s (fun x -> mask x /\ x =!= y));
    timeless_exists' (fun y -> p y ** pure (mask y) ** forevery_aux p s (fun x -> mask x /\ x =!= y))
      (fun y -> timeless_forevery_aux p s (fun x -> mask x /\ x =!= y))

let (forall+) #a (p: a -> slprop) : slprop =
  exists* (s: shape). forevery_aux (fun x -> p x) s (fun x -> True)

let timeless_forevery #a (p: a -> slprop) :
    Lemma (requires forall x. timeless (p x))
      (ensures timeless (op_forall_Plus p))
      [SMTPat (timeless (op_forall_Plus p))] =
  assert_norm (op_forall_Plus p ==
    exists* (s: shape). forevery_aux (fun x -> p x) s (fun x -> True));
  timeless_exists' (fun (s: shape) -> forevery_aux (fun x -> p x) s (fun x -> True))
    (fun s -> timeless_forevery_aux _ _ _)

ghost
fn forevery_intro_empty (#a:Type0) (p: a -> slprop)
  requires
    pure (forall (x:a). False)
  ensures
    forall+ (x:a). p x
{
  fold forevery_aux (fun x -> p x) Empty (fun x -> True);
  fold forall+ (x:a). p x
}

ghost
fn forevery_elim_empty (#a:Type0) (p: a -> slprop)
  requires
    pure (forall (x:a). False)
  requires
    forall+ (x:a). p x
{
  drop_ (forall+ (x:a). p x);
}

ghost
fn forevery_intro_false (#a:Type0) (p: a -> slprop)
  ensures
    forall+ (x:a {False}). p x
{
  forevery_intro_empty (fun (x:a {False}) -> p x);
}

ghost
fn rec aux_mono
  (#a:Type0)
  (p: a -> slprop)
  (#f g: a -> prop)
  (s: shape)
  (#mask: (x:a{f x} -> prop))
  (mask': (x:a{g x} -> prop))
  requires
    forevery_aux #(x:a{f x}) (fun x -> p x) s mask
  requires
    pure (forall (x:a). f x ==> g x /\ (mask x <==> mask' x))
  requires
    pure (forall (x:a). ~(f x) /\ g x ==> ~(mask' x))
  ensures
    forevery_aux #(x:a{g x}) (fun x -> p x) s mask'
  decreases
    s
{
  match s {
    Empty -> {
      assert rewrites_to s Empty;
      unfold forevery_aux #(x:a{f x}) (fun x -> p x) Empty mask;
      fold forevery_aux #(x:a{g x}) (fun x -> p x) Empty mask';
    }
    Fill s' -> {
      assert rewrites_to s (Fill s');
      unfold forevery_aux #(x:a{f x}) (fun x -> p x) (Fill s') mask; with pred. _;
      let pred': (x:a{g x} -> prop) = (fun (x:a) -> f x /\ pred x);
      aux_mono #a p #f g s' #(fun (x:a{f x}) -> id (mask x /\ ~(pred x) <: prop))
        (fun (x:a{g x}) -> id (mask' x /\ ~(pred' x) <: prop));
      let h = forallm_get_elim #(x:a{f x}) pred p;
      forallm_intro #(x:a{g x}) pred' p fn x { h x };
      fold forevery_aux #(x:a{g x}) (fun x -> p x) (Fill s') mask';
    }
    Insert s' -> {
      assert rewrites_to s (Insert s');
      unfold forevery_aux #(x:a{f x}) (fun x -> p x) (Insert s') mask; with y. _;
      aux_mono #a p #f g s' #(fun (x:a{f x}) -> id (mask x /\ ~(eq2 #(x:a{f x}) x y) <: prop))
        (fun (x:a{g x}) -> id (mask' x /\ ~(eq2 #(x:a{g x}) x y) <: prop));
      fold forevery_aux #(x:a{g x}) (fun x -> p x) (Insert s') mask';
    }
  }
}

ghost
fn forevery_insert
  (#a: Type0)
  (#f: a->prop)
  (p: a -> slprop)
  (y: a)
  requires
    forall+ (x:a {f x}). p x
  requires
    p y
  requires
    pure (~(f y))
  ensures
    forall+ (x:a {f x \/ y == x}). p x
{
  unfold (forall+ (x:a {f x}). p x); with s. _;
  aux_mono (fun (x:a) -> p x) (fun x -> f x \/ y == x) s
    (fun x -> True /\ ~(eq2 #(x: a{f x \/ eq2 #a y x}) x y));
  fold forevery_aux #(x: a{f x \/ eq2 #a y x})
    (fun x -> p x) (Insert s) (fun x -> True);
  fold (forall+ (x:a {f x \/ y == x}). p x);
}

ghost
fn forevery_fill
  (#a: Type0)
  (#f: a->prop)
  (p: a -> slprop)
  (pred: a -> prop)
  (g: (x:a{pred x} -> stt_ghost unit emp_inames emp (fun _ -> p x)))
  requires
    forall+ (x:a {f x}). p x
  requires
    pure (forall x. pred x ==> ~(f x))
  ensures
    forall+ (x:a {f x \/ pred x}). p x
{
  unfold (forall+ (x:a {f x}). p x); with s. _;
  aux_mono (fun (x:a) -> p x) (fun x -> f x \/ pred x) s
    (fun x -> True /\ ~(pred x));
  forallm_intro #(x: a{f x \/ pred x}) pred (fun x -> p x) g;
  fold forevery_aux #(x: a{f x \/ pred x})
    (fun x -> p x) (Fill s) (fun x -> True);
  fold (forall+ (x:a {f x \/ pred x}). p x);
}

ghost
fn forevery_rw_type
  (a:Type0)
  (b:Type{a == b})
  (f : a -> slprop)
  requires
    forall+ (x:a). f x
  ensures
    forall+ (x:b). f x
{
  rewrite
    forall+ (x:a). f x
  as
    forall+ (x:b). f x
}

ghost
fn forevery_refine_ext'
  (#a: Type0)
  (#f g: a->prop)
  (#_ : squash (forall x. f x <==> g x))
  (p: (x:a{f x} -> slprop))
  requires
    forall+ (x:a {f x}). p x
  ensures
    forall+ (w:a {g w}). p w
{
  RefinementExtensionality.refext a f g;
  forevery_rw_type (x:a {f x}) (x:a {g x}) p;
}

ghost
fn forevery_refine_ext
  (#a: Type0)
  (#f g: a->prop)
  (p: a -> slprop)
  requires
    forall+ (x:a {f x}). p x
  requires
    pure (forall x. f x <==> g x)
  ensures
    forall+ (w:a {g w}). p w
{
  forevery_refine_ext' #a #f g p;
}

unfold let set_of #a (f: a->prop) = F.on_dom _ f
let set_ext #a (f g: a^->prop) : Lemma (requires forall x. f x <==> g x) (ensures f == g) =
  introduce forall x. f x == g x with PropositionalExtensionality.apply (f x) (g x);
  assert F.feq f g

ghost
fn rec aux_rec
  (#a: Type0)
  (p: a -> slprop)
  (#s: shape)
  (inv: (a -> prop) -> slprop)
  (ih_fill: (pred:(a -> prop) -> add:(a -> prop) { forall x. add x ==> ~(pred x) } ->
    f:((x:a { add x }) -> stt_ghost unit emp_inames emp (fun _ -> p x)) ->
    stt_ghost unit emp_inames (inv pred)
      (fun _ -> inv (set_of fun x -> pred x \/ add x))))
  (ih_insert: (pred:(a -> prop) -> x:a ->
    stt_ghost unit emp_inames (inv pred ** p x ** pure (~(pred x)))
      (fun _ -> inv (set_of fun y -> pred y \/ x == y))))
  (mask: a -> prop)
  requires
    forevery_aux #a p s mask
  requires
    inv (set_of fun _ -> False)
  ensures
    exists* (pred': a ^-> prop). inv pred' ** pure (forall x. pred' x <==> mask x)
  decreases s
{
  match s {
    Empty -> {
      unfold forevery_aux #a p Empty mask;
      set_ext (set_of fun _ -> False) (set_of mask);
      rewrite each set_of (fun (x:a) -> (False<:prop)) as (set_of mask);
    }
    Fill s' -> {
      unfold forevery_aux #a p (Fill s') mask; with pred. _;
      aux_rec p #s' inv ih_fill ih_insert (fun (x:a) -> id (mask x /\ ~(pred x) <: prop));
      with mask'. assert inv mask';
      assert pure (forall x. mask' x <==> mask x /\ ~(pred x));
      let h = forallm_get_elim #a pred p;
      ih_fill mask' (set_of fun x -> mask x /\ pred x) fn x { h x };
    }
    Insert s' -> {
      unfold forevery_aux #a p (Insert s') mask; with y. _;
      aux_rec p #s' inv ih_fill ih_insert (fun (x:a) -> id (mask x /\ x =!= y <: prop));
      with mask'. assert inv mask';
      ih_insert mask' y;
    }
  }
}

ghost
fn forevery_rec
  (#a: Type0)
  (p: a -> slprop)
  (inv: (a -> prop) -> slprop)
  (ih_fill: (pred:(a -> prop) -> add:(a -> prop) { forall x. add x ==> ~(pred x) } ->
    f:((x:a { add x }) -> stt_ghost unit emp_inames emp (fun _ -> p x)) ->
    stt_ghost unit emp_inames (inv pred)
      (fun _ -> inv (set_of fun x -> pred x \/ add x))))
  (ih_insert: (pred:(a -> prop) -> x:a ->
    stt_ghost unit emp_inames (inv pred ** p x ** pure (~(pred x)))
      (fun _ -> inv (set_of fun y -> pred y \/ x == y))))
  requires
    forall+ x. p x
  requires
    inv (set_of fun _ -> False)
  ensures
    inv (set_of fun _ -> True)
{
  unfold (forall+ (x:a). p x);
  aux_rec (fun x -> p x) inv ih_fill ih_insert _;
  with pred'. assert inv pred';
  set_ext pred' (set_of fun _ -> True);
  rewrite each pred' as set_of fun _ -> True
}

ghost
fn forevery_ext
  (#a:Type0)
  (f : a -> slprop)
  (g : a -> slprop { forall x. f x == g x })
  requires
    forall+ (x:a). f x
  ensures
    forall+ (x:a). g x
{
  rewrite (forall+ (x:a). f x) as (forall+ (x:a). g x)
}

ghost
fn forevery_ext_2
  (#a:Type0)
  (#b:Type0)
  (f : a -> b -> slprop)
  (g : a -> b -> slprop)
  requires
    pure (forall x y. f x y == g x y)
  requires
    forall+ (x:a) (y:b). f x y
  ensures
    forall+ (x:a) (y:b). g x y
{
  rewrite (forall+ (x:a) (y:b). f x y)
    as (forall+ (x:a) (y:b). g x y);
}

ghost
fn forevery_intro_pure (#a:Type0) (p: a -> prop)
  requires
    pure (forall x. p x)
  ensures
    forall+ x. pure (p x)
{
  forevery_intro_false (fun x -> pure (p x));
  forevery_fill
    #a
    #(fun _ -> False)
    (fun x -> pure (p x))
    (fun _ -> True)
    fn x {};
  forevery_rw_type (x:a{False \/ True}) a (fun x -> pure (p x));
}

ghost
fn forevery_map
  (#a:Type0)
  (p1 p2 : a -> slprop)
  (f : (x:a -> stt_ghost unit emp_inames (p1 x) (fun _ -> p2 x)))
  requires
    forall+ (x:a). p1 x
  ensures
    forall+ (x:a). p2 x
{
  forevery_intro_false p2;
  forevery_rec p1 (fun pred -> forall+ (x:a { pred x }). p2 x)
    fn pred add g { forevery_fill p2 add fn x { g x; f x } }
    fn pred x { f x; forevery_insert p2 x };
  forevery_refine_ext (fun _ -> True) p2;
}

ghost
fn forevery_intro_pure_2 (#a:Type0) (#b:Type0) (p: a -> b -> prop)
  requires
    pure (forall x y. p x y)
  ensures
    forall+ (x:a) (y:b). pure (p x y)
{
  forevery_intro_false (fun (x:a) -> forall+ (y:b). pure (p x y));
  forevery_fill
    #a
    #(fun _ -> False)
    (fun x -> forall+ (y:b). pure (p x y))
    (fun _ -> True)
    fn x { forevery_intro_pure #b (fun y -> p x y) };
  forevery_rw_type (x:a{False \/ True}) a (fun x -> forall+ (y:b). pure (p x y));
}

ghost
fn rewrite_cond_ext (p:prop) (s1 s2:slprop) (q:prop)
requires
  cond (t2b p) s1 s2
requires
  (pure (p <==> q))
ensures cond (t2b q) s1 s2
{
  rewrite cond (t2b p) s1 s2 as cond (t2b q) s1 s2
}

ghost
fn forevery_remove'
  (#a: Type0)
  (f: a->prop)
  (p: a -> slprop)
  (y: a { f y })
  requires
    forall+ (x:a {f x}). p x
  ensures
    forall+ (x:a {f x /\ x =!= y}). p x
  ensures
    p y
{
  forevery_intro_false p;
  intro_cond_false (p y) emp; rewrite each false as t2b False;
  forevery_refine_ext #_ #(fun _ -> l_False) (fun z -> f z /\ ~(z == y) /\ l_False) p;
  forevery_rec #(x:a{f x}) p (fun pred ->
      cond (t2b (pred y)) (p y) emp **
      forall+ (z:a { f z /\ z =!= y /\ pred z }). p z)
    fn pred add g {
      forevery_fill p (fun z -> f z /\ z =!= y /\ add z)
        fn x { g x };
      forevery_refine_ext (fun (z: a) -> f z /\ ~(eq2 #a z y) /\ (pred z \/ add z <: prop)) p;
      let b = t2b (add y);
      if b {
        elim_cond_false (t2b (pred y)) (p y) emp;
        g y;
        rewrite p y as cond (t2b (pred y \/ add y)) (p y) emp;
      } else {
        rewrite cond (t2b (pred y)) (p y) emp
        as cond (t2b (pred y \/ add y)) (p y) emp;
      }
    }
    fn pred x {
      let b = t2b (x == y);
      if b {
        assert rewrites_to y x;
        elim_cond_false (t2b (pred y)) (p y) emp;
        rewrite p x as cond (t2b (pred x \/ x == y)) (p y) emp;
        rewrite_cond_ext _ _ _ (pred x \/ eq2 #(x:a{f x}) x x);
        forevery_refine_ext (fun (z: a) -> f z /\ ~(z == y) /\ (pred z \/ eq2 #(x:a{f x}) x z)) p;
      } else {
        forevery_insert p x;
        forevery_refine_ext (fun (z: a) -> f z /\ ~(z == y) /\ (pred z \/ eq2 #(x:a{f x}) x z)) p;
        rewrite cond (t2b (pred y)) (p y) emp
        as cond (t2b (pred y \/ eq2 #(x:a{f x}) x y)) (p y) emp;
      }
    };
  forevery_refine_ext #_ #(fun z -> f z /\ ~(z == y) /\ l_True) (fun z -> f z /\ ~(z == y)) p;
  elim_cond_true _ (p y) emp;
}

ghost
fn forevery_remove
  (#a: Type0)
  (p: a -> slprop)
  (y: a)
  requires
    forall+ (x:a). p x
  ensures
    forall+ (x:a {x =!= y}). p x
  ensures
    p y
{
  forevery_remove' #a (fun _ -> True) p y;
  forevery_rw_type (x:a{True /\ x =!= y}) (x:a{x =!= y}) p;
  ()
}

ghost
fn forevery_intro_fill (#a: Type0) (p: a -> slprop)
  (f: (x:a -> stt_ghost unit emp_inames emp (fun _ -> p x)))
  ensures
    forall+ x. p x
{
  forevery_intro_false p;
  forevery_fill p (fun _ -> True) fn x { f x };
  forevery_rw_type (x:a{False \/ True}) a p;
}

ghost
fn forevery_unrefine
  (#a: Type0)
  (#f: a->prop)
  (p: a -> slprop)
  requires
    forall+ (x:a {f x}). p x
  requires
    pure (forall x. f x)
  ensures
    forall+ x. p x
{
  forevery_refine_ext (fun _ -> True) _;
}

ghost
fn forevery_singleton_intro'
  (#a:Type0)
  (p : a -> slprop)
  (x: a)
  requires
    pure (forall (y: a). x == y)
  requires
    p x
  ensures
    forall+ (x:a). p x
{
  forevery_intro_false p;
  forevery_insert p x;
  forevery_unrefine p;
}

ghost
fn forevery_singleton_elim'
  (#a:Type0)
  (p : a -> slprop)
  (x: a)
  requires
    pure (forall (y: a). x == y)
  requires
    forall+ (x:a). p x
  ensures
    p x
{
  forevery_remove p x;
  forevery_elim_empty (fun (y: a{~(y == x)}) -> p y);
}

ghost
fn forevery_refine_split
  (#a:Type0)
  (p: a -> slprop)
  (f: a -> prop)
  requires
    forall+ x. p x
  ensures
    forall+ (x:a{f x}). p x
  ensures
    forall+ (x:a{~(f x)}). p x
{
  forevery_intro_false p;
  forevery_intro_false p;
  forevery_rw_type (z:a{False}) (z:a{f z /\ False}) p;
  forevery_rw_type (z:a{False}) (z:a{~(f z) /\ False}) p;
  forevery_rec p
    (fun pred ->
      (forall+ (z:a{f z /\ pred z}). p z) **
      (forall+ (z:a{~(f z) /\ pred z}). p z))
    fn pred add g {
      forevery_fill #a #(fun z -> f z /\ pred z) p (fun z -> add z /\ f z) fn x { g x };
      forevery_fill #a #(fun z -> ~(f z) /\ pred z) p (fun z -> add z /\ ~(f z)) fn x { g x };
      forevery_refine_ext #a
        #(fun (x: a) -> f x /\ pred x \/ add x /\ f x)
        (fun (x: a) -> f x /\ (pred x \/ add x))
        p;
      forevery_refine_ext #a
        #(fun (x: a) -> ~(f x) /\ pred x \/ add x /\ ~(f x))
        (fun (x: a) -> ~(f x) /\ (pred x \/ add x))
        p;
    }
    fn pred x {
      let b = t2b (f x);
      if b {
        forevery_insert #a #(fun z -> f z /\ pred z) p x;
        forevery_refine_ext #a
          #(fun (z: a) -> (f z /\ pred z) \/ x == z)
          (fun (z: a) -> f z /\ (pred z \/ x == z))
          p;
        forevery_refine_ext #a
          #(fun (z: a) -> ~(f z) /\ pred z)
          (fun (z: a) -> ~(f z) /\ (pred z \/ x == z))
          p;
      } else {
        forevery_insert #a #(fun z -> ~(f z) /\ pred z) p x;
        forevery_refine_ext #a
          #(fun (z: a) -> (~(f z) /\ pred z) \/ x == z)
          (fun (z: a) -> ~(f z) /\ (pred z \/ x == z))
          p;
        forevery_refine_ext #a
          #(fun (z: a) -> (f z) /\ pred z)
          (fun (z: a) -> (f z) /\ (pred z \/ x == z))
          p;
      }
    };
  ();
  forevery_rw_type (z:a{f z /\ True})    (z:a{f z}) p;
  forevery_rw_type (z:a{~(f z) /\ True}) (z:a{~(f z)}) p;
}

