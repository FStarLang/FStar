ghost
fn forevery_factor
  (n : nat)
  (d1 : nat) (d2 : nat { n == d1 * d2 })
  (p : fin n -> slprop)
  requires
    forall+ (i:fin n). p i
  ensures
    forall+ (i1:fin d1) (i2:fin d2). p (i1 * d2 + i2)
{
  forevery_rw_size n (d1 * d2);
  forevery_iso (bij_sym <| bij_nat_prod #d1 #d2) _;
  forevery_unflatten #(fin d1) #(fin d2) (fun i1 i2 -> p (i1 * d2 + i2));
}

ghost
fn forevery_factor'
  (n : nat)
  (d1 : nat) (d2 : nat { n == d1 * d2 })
  (p : fin d1 -> fin d2 -> slprop)
  requires
    forall+ (i:fin n). p (i/d2) (i%d2)
  ensures
    forall+ (i1:fin d1) (i2:fin d2). p i1 i2
{
  forevery_factor n d1 d2 (fun i -> p (i / d2) (i % d2));
  forevery_ext_2
    (fun (i1 : fin d1) (i2 : fin d2) -> p ((i1 * d2 + i2) / d2) ((i1 * d2 + i2) % d2))
    (fun (i1 : fin d1) (i2 : fin d2) -> p i1 i2);
  ();
}

ghost
fn forevery_unfactor
  (n : nat)
  (d1 : nat) (d2 : nat { n == d1 * d2 })
  (p : fin n -> slprop)
  requires
    forall+ (i1:fin d1) (i2:fin d2). p (i1 * d2 + i2)
  ensures
    forall+ (i:fin n). p i
{
  forevery_flatten #(fin d1) #(fin d2) (fun i1 i2 -> p (i1 * d2 + i2));
  forevery_iso (bij_nat_prod #d1 #d2) _;
  forevery_rw_size (d1 * d2) n;
  forevery_ext _ p;
}

ghost
fn forevery_unfactor'
  (n : nat)
  (d1 : nat) (d2 : nat { n == d1 * d2 })
  (p : fin d1 -> fin d2 -> slprop)
  requires
    forall+ (i1:fin d1) (i2:fin d2). p i1 i2
  ensures
    forall+ (i:fin n). p (i/d2) (i%d2)
{
  rewrite
    forall+ (i1: fin d1) (i2: fin d2). p i1 i2
  as
    forall+ (i1: fin d1) (i2: fin d2).
      p ((i1 * d2 + i2) / d2) ((i1 * d2 + i2) % d2);
  forevery_unfactor n d1 d2 (fun i -> p (i/d2) (i%d2));
}

ghost
fn forevery_map_2
  (#a:Type0)
  (#b:Type0)
  (p1 p2 : a -> b -> slprop)
  (f : (x:a -> y:b -> stt_ghost unit emp_inames (p1 x y) (fun _ -> p2 x y)))
  requires
    forall+ (x:a) (y:b). p1 x y
  ensures
    forall+ (x:a) (y:b). p2 x y
{
  forevery_map #a
    (fun x -> forevery b (fun y -> p1 x y))
    (fun x -> forevery b (fun y -> p2 x y))
    (fun x -> forevery_map (fun y -> p1 x y)
                          (fun y -> p2 x y)
                          (f x));
}

ghost
fn forevery_map'
  (#a:Type0)
  (#b:Type0 { a == b })
  (p1 : a -> slprop)
  (p2 : b -> slprop)
