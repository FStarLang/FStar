fn forevery_iso
  (#a:Type0)
  (#b:Type0)
  (bij : a =~ b)
  (p : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    forall+ (y:b). p (bij.left y)
{
  forevery_intro_false (fun y -> p (bij.left y));
  forevery_rec p (fun pred -> forall+ (y:b { pred (bij.left y) }). p (bij.left y))
    fn pred add g {
      forevery_fill (fun y -> p (bij.left y)) (fun z -> add (bij.left z))
        fn x { g (bij.left x) }
    }
    fn pred x {
      rewrite p x as p (bij.left (bij.right x));
      forevery_insert (fun y -> p (bij.left y)) (bij.right x);
      forevery_refine_ext (fun y -> pred (bij.left y) \/ x == bij.left y) (fun y -> p (bij.left y));
    }
}

let snd_bij #a #b (x: a) : (b =~ (xy: (a & b) { x == fst xy })) =
  {
    right = (fun y -> ((x,y) <: (xy: (a&b) {x == fst xy})));
    left = (fun xy -> snd xy);
    right_left = (fun _ -> ());
    left_right = (fun _ -> ());
  }

let snd_bij_dep #a (#b : a -> Type) (x: a) : (b x =~ (xy: (x:a & b x) { x == xy._1 })) =
  {
    right = (fun y -> ((|x,y|) <: (xy: (x:a & b x) {x == xy._1})));
    left = (fun xy -> xy._2);
    right_left = (fun _ -> ());
    left_right = (fun _ -> ());
  }

