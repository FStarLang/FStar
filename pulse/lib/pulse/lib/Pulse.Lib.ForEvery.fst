let bij_either_inl a b : ((x: either a b { Inl? x }) =~ a) =
  mk_bijection #(x: either a b { Inl? x }) Inl?.v (fun x -> Inl x) easy easy

let bij_either_inr a b : ((x: either a b { ~(Inl? x) }) =~ b) =
  mk_bijection #(x: either a b { ~(Inl? x) }) (fun x -> Inr?.v x) (fun x -> Inr x) easy easy

ghost
fn forevery_split_either
  (#a #b : Type0)
  (p : either a b -> slprop)
  requires
    forall+ (x:either a b). p x
  ensures
    (forall+ (x:a). p (Inl x)) **
    (forall+ (x:b). p (Inr x))
{
  forevery_refine_split p (fun x -> Inl? x);
  forevery_iso (bij_either_inl a b) p;
  forevery_ext (fun x -> p ((bij_either_inl a b).left x)) (fun x -> p (Inl x));
  forevery_iso (bij_either_inr a b) p;
  forevery_ext (fun x -> p ((bij_either_inr a b).left x)) (fun x -> p (Inr x));
}

ghost
fn forevery_join_either
  (#a #b : Type0)
  (p : either a b -> slprop)
  requires
    (forall+ (x:a). p (Inl x)) **
    (forall+ (x:b). p (Inr x))
  ensures
    forall+ (x:either a b). p x
{
  forevery_ext (fun x -> p (Inl x)) (fun x -> p ((bij_either_inl a b).left x));
  forevery_ext (fun x -> p (Inr x)) (fun x -> p ((bij_either_inr a b).left x));
  forevery_iso_back (bij_either_inl a b) p;
  forevery_iso_back (bij_either_inr a b) p;
  forevery_refine_join p (fun x -> Inl? x) (fun x -> ~(Inl? x));
  forevery_unrefine p;
}

ghost
fn rec __forevery_map_extra_nat
  (#n : nat)
  (m : nat{m <= n})
  (k : slprop)
  (p1 p2 : fin n -> slprop)
  (f : (x:fin n -> stt_ghost unit emp_inames (k ** p1 x) (fun _ -> k ** p2 x)))
  preserves k
  requires
    (forall+ (x : fin n{x < m}). p1 x) **
    (forall+ (x : fin n{x >= m}). p2 x)
  ensures
    (forall+ (x : fin n). p2 x)
  decreases m
{
  if (m = 0) {
    rewrite each m as 0;
    forevery_elim_empty #(x: fin n { x < 0 }) p1;
    forevery_unrefine _;
    ()
  } else {
    forevery_remove' #(fin n) (fun x -> x < m) p1 (m-1);
    f (m-1);
    forevery_refine_ext #(fin n)
      #(fun x -> x < m /\ ~(eq2 #(fin n) x (m-1)))
      (fun x -> x < m-1)
      p1;
    forevery_insert p2 (m-1);
    forevery_refine_ext #(fin n)
      #(fun x -> x >= m \/ eq2 #(fin n) (m-1) x)
      (fun x -> x >= m-1)
      p2;
    __forevery_map_extra_nat (m-1) k p1 p2 f;
  }
}

ghost
fn forevery_map_extra_nat
  (#n : nat)
  (k : slprop)
  (p1 p2 : fin n -> slprop)
  (f : (x:fin n -> stt_ghost unit emp_inames (k ** p1 x) (fun _ -> k ** p2 x)))
  preserves k
  requires
    forall+ (x : fin n). p1 x
  ensures
    forall+ (x : fin n). p2 x
{
    forevery_refine_ext #(fin n)
      (fun x -> x < n)
      p1;
  forevery_intro_empty #(x : fin n{x >= n}) p2;
  __forevery_map_extra_nat #n n k p1 p2 f;
}

ghost
fn forevery_map_extra
  (#a:Type0) {| d : enumerable a |}
  (k : slprop)
  (p1 p2 : a -> slprop)
  (f : (x:a -> stt_ghost unit emp_inames (k ** p1 x) (fun _ -> k ** p2 x)))
  preserves k
  requires
    forall+ (x:a). p1 x
  ensures
    forall+ (x:a). p2 x
{
  forevery_iso d.bij _;
  ghost
  fn f' (x: fin (cardinal a #_))
    requires k ** p1 (of_nat x)
    ensures  k ** p2 (of_nat x)
  {
    f (of_nat x)
  };
  forevery_map_extra_nat #(cardinal a #_) k _ _ f';
  forevery_iso_back d.bij _;
}

let bij_nested_3
     (#a #b #c : Type0)
  : ((a & b & c) =~ ((a & b) & c)) =
  mk_bijection
    #(a & b & c)
    #((a & b) & c)
    (fun x -> ((x._1, x._2), x._3))
    (fun y -> (y._1._1, y._1._2, y._2))
    easy easy

ghost
fn forevery_flatten3'
  (#a #b #c : Type0)
  (f : a & b & c -> slprop)
  requires
    forall+ (x:a) (y:b) (z:c). f (x, y, z)
  ensures
    forall+ (xyz : a & b & c). f xyz
{
  forevery_flatten _;
  forevery_flatten _;
  forevery_iso (bij_sym <| bij_nested_3 #a #b #c) _;
  forevery_ext
    _
    (fun (xyz: a & b & c) -> f xyz);
  ();
}

ghost
fn forevery_unflatten3'
  (#a #b #c : Type0)
  (f : a & b & c -> slprop)
  requires
    forall+ (xyz : a & b & c). f xyz
  ensures
    forall+ (x:a) (y:b) (z:c). f (x, y, z)
{
  forevery_iso (bij_nested_3 #a #b #c) _;
  forevery_ext
    _
    (fun (xyz : ((a & b) & c)) -> f (xyz._1._1, xyz._1._2, xyz._2));
  forevery_unflatten' _;
  forevery_unflatten' _;
  ();
}

let bij_nested_4
     (#a #b #c #d : Type0)
  : ((a & b & c & d) =~ (((a & b) & c) & d)) =
  mk_bijection
    #(a & b & c & d)
    #(((a & b) & c) & d)
    (fun x -> ((((x._1, x._2), x._3), x._4)))
    (fun y -> (y._1._1._1, y._1._1._2, y._1._2, y._2))
    easy easy

ghost
fn forevery_flatten4'
  (#a #b #c #d : Type0)
  (f : a & b & c & d -> slprop)
  requires
    forall+ (x:a) (y:b) (z:c) (w:d). f (x, y, z, w)
  ensures
    forall+ (xyzw : a & b & c & d). f xyzw
{
  forevery_flatten _;
  forevery_flatten _;
  forevery_flatten _;
  forevery_iso (bij_sym <| bij_nested_4 #a #b #c #d) _;
  forevery_ext
    _
    (fun (xyzw: a & b & c & d) -> f xyzw);
  ();
}

ghost
fn forevery_unflatten4'
  (#a #b #c #d : Type0)
  (f : a & b & c & d -> slprop)
  requires
    forall+ (xyzw : a & b & c & d). f xyzw
  ensures
    forall+ (x:a) (y:b) (z:c) (w:d). f (x, y, z, w)
{
  forevery_iso (bij_nested_4 #a #b #c #d) _;
  forevery_ext
    _
    (fun (xyzw : (((a & b) & c) & d)) -> f (xyzw._1._1._1, xyzw._1._1._2, xyzw._1._2, xyzw._2));
  forevery_unflatten' _;
  forevery_unflatten' _;
  forevery_unflatten' _;
  ();
