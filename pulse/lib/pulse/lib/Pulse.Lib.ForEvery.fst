  (n1 : nat)
  (n2 : nat{n1 == n2})
  (n3 : nat)
  (n4 : nat{n3 == n4})
  (#p : fin n1 -> fin n3 -> slprop)
  requires
    forall+ (i : fin n1) (j : fin n3). p i j
  ensures
    forall+ (i : fin n2) (j : fin n4). p i j
{
