fn forevery_unflatten
  (#a:Type0)
  (#b:Type0)
  (f : a -> b -> slprop)
  requires
    forall+ (xy : a & b). f xy._1 xy._2
  ensures
    forall+ (x:a) (y:b). f x y
{
  forevery_intro_fill (fun x -> forall+ (y:b{False}). f x y)
    fn x { forevery_intro_false (fun y -> f x y) };
  forevery_rec #(a&b) (fun xy -> f xy._1 xy._2)
    (fun pred -> forall+ (x:a) (y:b{ pred (x, y) }). f x y)
    fn pred add g {
      forevery_map
        (fun x -> forall+ (y:b { pred (x, y) }). f x y)
        (fun x -> forall+ (y:b { pred (x, y) \/ add (x, y) }). f x y)
        fn x {
          forevery_fill (f x) (fun y -> add (x, y)) fn y {
            g (x, y);
            with x' y'. rewrite f x' y' as f x y;
          };
