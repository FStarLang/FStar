fn forevery_dup (#a: Type0) (p: a -> slprop) {| (x:a -> duplicable (p x)) |} ()
  : duplicable_f (forall+ (x: a). p x) =
{
  forevery_map p (fun x -> p x ** p x) fn x { dup (p x) () };
  forevery_unzip p p;
}

