fn forevery_fin_pop_shift
  (n: nat { n > 0 })
  (p: fin n -> slprop)
  requires
    forall+ (i: fin n). p i
  ensures
    forall+ (i: fin (n-1)). p (i + 1)
  ensures
    p 0
{
  forevery_iso (bij_mirror_n n) p;
  forevery_fin_pop n _;
  rewrite p ((bij_mirror_n n).left (n-1)) as p 0;

  forevery_ext #(fin (n-1)) _
    (fun (i: fin (n-1)) -> p (n - 1 - i));

  forevery_iso (bij_mirror_n (n-1))
    (fun i -> p (n - 1 - i));

  forevery_ext #(fin (n-1)) _
    (fun (i: fin (n-1)) -> p (i + 1));
