  forevery_flatten #a #b _;
  forevery_extract_if (z, w) _;
  forevery_unflatten' #a #b _;
  rewrite p (z,w)._1 (z,w)._2 as p z w;
  with q. rewrite
    (forall+ (x:a) (y:b). q x y)
  as
    (forall+ (x:a) (y:b).
      unless ((x, y) == (z, w)) (p x y));
}

ghost
fn forevery_boolean_split
  (#a:Type0)
  (b : a -> bool)
  (p : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    (forall+ (x:a). if b x then emp else p x) **
    (forall+ (x:a). if b x then p x else emp)
{
  forevery_refine_split p (fun x -> b x);
  forevery_unrefine_pred p (fun x -> b x);
  forevery_unrefine_pred p (fun x -> ~(b x));
  forevery_ext (fun x -> when_ (~(b x)) (p x)) (fun x -> if b x then emp else p x);
  forevery_ext (fun x -> when_ (b x) (p x)) (fun x -> if b x then p x else emp);
}

ghost
fn forevery_boolean_join
  (#a:Type0)
  (b : a -> bool)
  (p1 p2 : a -> slprop)
  requires
    (forall+ (x:a). if b x then p1 x else emp) **
    (forall+ (x:a). if b x then emp else p2 x)
  ensures
    (forall+ (x:a). if b x then p1 x else p2 x)
{
  forevery_ext (fun x -> if b x then p1 x else emp) (fun x -> when_ (b x) (p1 x));
  forevery_refine_pred p1 (fun x -> b x);
  forevery_ext (fun x -> if b x then emp else p2 x) (fun x -> when_ (~(b x)) (p2 x));
  forevery_refine_pred p2 (fun x -> ~(b x));
  forevery_ext #(x:a{ b x }) p1 (fun x -> if b x then p1 x else p2 x);
  forevery_ext #(x:a{ ~(b x) }) p2 (fun x -> if b x then p1 x else p2 x);
  forevery_refine_join (fun x -> if b x then p1 x else p2 x) (fun x -> b x) (fun x -> ~(b x));
  forevery_unrefine _;
}

