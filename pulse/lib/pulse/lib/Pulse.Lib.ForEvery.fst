fn forevery_unzip
  (#a:Type0)
  (p1 p2 : a -> slprop)
  requires
    forall+ (x:a). p1 x ** p2 x
  ensures
    (forall+ (x:a). p1 x) **
    (forall+ (x:a). p2 x)
{
  forevery_intro_false p1;
  forevery_intro_false p2;
  forevery_rec (fun x -> p1 x ** p2 x)
      (fun pred -> (forall+ (x:a{pred x}). p1 x) ** (forall+ (x:a{pred x}). p2 x))
    fn pred add f {
      forevery_fill p1 add fn x { f x; drop_ (p2 x) };
      forevery_fill p2 add fn x { f x; drop_ (p1 x) };
    }
    fn pred x {
      forevery_insert p1 x;
      forevery_insert p2 x;
    };
}

