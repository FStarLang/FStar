ghost
fn forevery_extract_if_2
  (#a:Type0)
  (#b:Type0)
  (z : a) (w : b)
  (p : a -> b -> slprop)
  requires
    forall+ (x:a) (y:b). p x y
  ensures
    p z w **
    (forall+ (x:a) (y:b).
      unless ((x, y) == (z, w)) (p x y))
