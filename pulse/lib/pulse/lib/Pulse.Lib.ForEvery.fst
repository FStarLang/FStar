  requires
    forall+ (x:a). p1 x
  ensures
    forall+ (x:b). p2 x
{
  rewrite each a as b;
  forevery_map #b p1 p2 fn x { f x x };
}

ghost
fn forevery_zip_2
  (#a:Type0)
  (#b:Type0)
  (p1 p2 : a -> b -> slprop)
  requires
    (forall+ (x:a) (y:b). p1 x y) **
    (forall+ (x:a) (y:b). p2 x y)
  ensures
    forall+ (x:a) (y:b). p1 x y ** p2 x y
{
  forevery_zip (fun (x:a) -> forall+ (y:b). p1 x y) _;
  forevery_map _ _ (fun x -> forevery_zip (fun (y:b) -> p1 x y) _);
}

ghost
fn forevery_unzip_2
  (#a:Type0)
  (#b:Type0)
  (p1 p2 : a -> b -> slprop)
  requires
    forall+ (x:a) (y:b). p1 x y ** p2 x y
  ensures
    (forall+ (x:a) (y:b). p1 x y) **
    (forall+ (x:a) (y:b). p2 x y)
{
  forevery_map _ _ (fun x -> forevery_unzip (fun (y:b) -> p1 x y) _);
  forevery_unzip (fun (x:a) -> forall+ (y:b). p1 x y) _;
}

ghost
fn forevery_pad
  (n1 : nat)
  (n2 : nat{n1 <= n2})
  (p : fin n1 -> slprop)
  requires
    forall+ (i : fin n1). p i
  ensures
    forall+ (i : fin n2). pad_f n2 p i
{
  forevery_ext #(fin n1) p (fun (i: fin n1) -> pad_f n2 p (fin_coerce i));
  forevery_fin_extend n2 (fun (i: fin n1) -> pad_f n2 p (fin_coerce i));
  forevery_fill (fun (i: fin n2) -> pad_f n2 p i)
    (fun i -> i >= n1) fn i { rewrite emp as pad_f #n1 n2 p i };
  forevery_unrefine (fun (i: fin n2) -> pad_f n2 p i);
}

ghost
fn forevery_unpad
  (n1 : nat)
  (n2 : nat{n1 <= n2})
  (p : fin n1 -> slprop)
  requires
    forall+ (i : fin n2). pad_f n2 p i
  ensures
    forall+ (i : fin n1). p i
{
  forevery_refine_split (fun (i: fin n2) -> pad_f n2 p i) (fun i -> i < n1);
  drop_ (forall+ (i: fin n2 { ~(i < n1) }). pad_f n2 p i);
  forevery_fin_restrict n2 (fun (i: fin n1) -> pad_f n2 p (fin_coerce i));
  forevery_ext #(fin n1) (fun (i: fin n1) -> pad_f n2 p (fin_coerce i)) p;
}

ghost
fn forevery_extract
  (#a:Type0)
  (z : a)
  (p : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    p z ** (p z @==> forall+ (x:a). p x)
{
  forevery_remove p z;
  intro (p z @==> forall+ (x:a). p x) #(forall+ (x:a{x =!= z}). p x) fn _ {
    forevery_insert p z;
    forevery_unrefine p;
  }
}

// FIXME: Type-class inference fails inside Pulse?!?
let forevery_extract'_aux #a (z:a) (p: a->slprop) =
  intro (forall* (p' : a -> slprop).
      p' z ** pure (forall (x:a{x =!= z}). p' x == p x)
        @==> (forall+ (x:a). p' x))
    #(forall+ (x:a{x =!= z}). p x)

ghost
fn forevery_extract'
  (#a:Type0)
  (z : a)
  (p  : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    p z **
      (forall* (p' : a -> slprop).
        p' z ** pure (forall (x:a{x =!= z}). p' x == p x)
          @==> (forall+ (x:a). p' x))
{
  forevery_remove p z;
  forevery_extract'_aux z p fn _ p' {
    forevery_map #(x:a{x =!= z}) p p'
      fn x { rewrite p x as p' x };
    forevery_insert p' z;
    forevery_unrefine p';
  };
}

ghost
fn forevery_extract_2
  (#a:Type0)
  (#b:Type0)
  (z : a) (w : b)
  (p : a -> b -> slprop)
  requires
    forall+ (x:a) (y:b). p x y
  ensures
    p z w ** (p z w @==> forall+ (x:a) (y:b). p x y)
{
  forevery_flatten p;
  forevery_remove (fun (xy: a & b) -> p xy._1 xy._2) (z, w);
  with z' w'. rewrite p z' w' as p z w;
  intro (p z w @==> forall+ (x:a) (y:b). p x y)
    #(forall+ (xy: a&b { xy =!= (z,w) }). p xy._1 xy._2)
    fn _ {
      rewrite p z w as p (z,w)._1 (z,w)._2;
      forevery_insert (fun (xy: a&b) -> p xy._1 xy._2) (z, w);
      forevery_unrefine (fun (xy: a&b) -> p xy._1 xy._2);
      forevery_unflatten p;
    };
}

ghost
fn forevery_extract_if
  (#a:Type0)
  (z : a)
  (p : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    p z **
    (forall+ (x:a). unless (x == z) (p x))
{
  forevery_remove p z;
  forevery_unrefine_pred p (fun x -> x =!= z);
  forevery_ext (fun x -> when_ (x =!= z) (p x)) (fun x -> unless (x == z) (p x));
}

ghost
fn forevery_extract_if_eqtype
  (#a:eqtype)
  (z : a)
  (p : a -> slprop)
  requires
    forall+ (x:a). p x
  ensures
    p z **
    (forall+ (x:a).
      if x = z then emp else p x)
{
  forevery_extract_if z p;
  rewrite
    (forall+ (x:a).
      if t2b (x == z) then emp else p x)
  as
    (forall+ (x:a).
      if x = z then emp else p x);
}

ghost
fn forevery_unextract_if
  (#a:Type0)
  (z : a)
  (p : a -> slprop)
  requires
    p z **
    (forall+ (x:a). unless (x == z) (p x))
  ensures
    forall+ (x:a). p x
{
  forevery_remove (fun x -> unless (x == z) (p x)) z;
  rewrite unless (z == z) (p z) as emp;
  // Need to annotate #a below
  forevery_ext
    (fun (x: a{x =!= z}) -> unless (eq2 #a x z) (p x))
    (fun (x: a{x =!= z}) -> p x);
  forevery_insert p z;
  forevery_unrefine p;
}

ghost
fn forevery_unextract_if_eqtype
  (#a:eqtype)
  (z : a)
  (p : a -> slprop)
  requires
